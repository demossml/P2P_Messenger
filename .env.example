NODE_ENV=development
PORT=3001
ALLOWED_ORIGIN=http://localhost:5173
JWT_PUBLIC_KEY=replace-with-public-key
JWT_PRIVATE_KEY=replace-with-private-key
REDIS_URL=redis://localhost:6379
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/p2p_messenger
TURN_SECRET=replace-with-turn-secret
TURN_HOST=turn.yourdomain.com
TURN_REALM=turn.yourdomain.com
TURN_CREDENTIALS_TTL_SECONDS=3600
ROOM_MAX_PEERS=8
ROOM_TTL_SECONDS=86400
WS_RATE_LIMIT_PER_SECOND=10
AUTH_AUDIT_LOG_MAX_ENTRIES=5000
AUTH_AUDIT_LOG_TTL_SECONDS=2592000
