{
  "name": "p2p-messenger",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:setup": "node scripts/setup-dev-env.mjs",
    "dev:infra": "docker compose up -d postgres redis coturn",
    "dev:server": "pnpm --filter @p2p/server dev",
    "dev:client": "pnpm --filter @p2p/client dev",
    "dev:all": "pnpm dev:setup && pnpm dev:infra && pnpm dev",
    "smoke:http": "node scripts/smoke-http.mjs",
    "smoke:ws": "node scripts/smoke-ws.mjs",
    "smoke:all": "pnpm smoke:http && pnpm smoke:ws",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:list": "playwright test --list",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "commitlint": "commitlint --edit"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/js": "^9.24.0",
    "@playwright/test": "^1.59.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-unicorn": "^58.0.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.1",
    "ws": "^8.20.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
