{
  "name": "p2p-messenger",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:setup": "node scripts/setup-dev-env.mjs",
    "dev:infra": "docker compose up -d postgres redis coturn",
    "dev:server": "pnpm --filter @p2p/server dev",
    "dev:client": "pnpm --filter @p2p/client dev",
    "dev:all": "pnpm dev:setup && pnpm dev:infra && pnpm dev",
    "smoke:http": "node scripts/smoke-http.mjs",
    "smoke:http:security": "node scripts/smoke-http.mjs",
    "smoke:http:security:retry": "node scripts/smoke-http-security-retry.mjs",
    "smoke:auth": "node scripts/smoke-auth.mjs",
    "smoke:auth:lifecycle-only": "node scripts/smoke-auth-lifecycle-only.mjs",
    "smoke:auth:reuse-only": "node scripts/smoke-auth-reuse-only.mjs",
    "smoke:auth:reuse-only:retry": "node scripts/smoke-auth-reuse-retry.mjs",
    "smoke:auth:audit-only": "node scripts/smoke-auth-audit-only.mjs",
    "smoke:auth:audit-only:retry": "node scripts/smoke-auth-audit-retry.mjs",
    "smoke:ws": "node scripts/smoke-ws.mjs",
    "smoke:ws:limits": "node scripts/smoke-ws-limits.mjs",
    "smoke:ws:strict": "pnpm smoke:ws:limits && pnpm smoke:ws:negative:retry",
    "smoke:ws:negative:retry": "node scripts/smoke-ws-negative-retry.mjs",
    "smoke:minimal": "pnpm smoke:http && pnpm smoke:ws",
    "smoke:minimal:retry": "node scripts/smoke-minimal-retry.mjs",
    "smoke:ws:negative": "node scripts/smoke-ws-negative.mjs",
    "smoke:all": "pnpm smoke:http && pnpm smoke:auth && pnpm smoke:ws && pnpm smoke:ws:limits && pnpm smoke:ws:negative",
    "load:k6:signaling": "k6 run scripts/load/signaling-k6.js",
    "load:k6:signaling:quick": "K6_STAGE_1=5s K6_STAGE_2=5s K6_STAGE_3=2s K6_VUS_1=5 K6_VUS_2=10 pnpm load:k6:signaling",
    "load:k6:signaling:quick:summary": "mkdir -p artifacts/k6 && K6_STAGE_1=5s K6_STAGE_2=5s K6_STAGE_3=2s K6_VUS_1=5 K6_VUS_2=10 k6 run --summary-export=artifacts/k6/signaling-quick-summary.json scripts/load/signaling-k6.js",
    "load:k6:signaling:stress": "K6_STAGE_1=8s K6_STAGE_2=10s K6_STAGE_3=4s K6_VUS_1=30 K6_VUS_2=60 K6_SIGNALING_CONNECT_P95_MS=200 K6_SIGNALING_SESSION_P95_MS=1200 pnpm load:k6:signaling",
    "load:k6:signaling:stress:summary": "mkdir -p artifacts/k6 && K6_STAGE_1=8s K6_STAGE_2=10s K6_STAGE_3=4s K6_VUS_1=30 K6_VUS_2=60 K6_SIGNALING_CONNECT_P95_MS=200 K6_SIGNALING_SESSION_P95_MS=1200 k6 run --summary-export=artifacts/k6/signaling-stress-summary.json scripts/load/signaling-k6.js",
    "load:k6:compare": "node scripts/load/compare-k6-summary.mjs",
    "e2e": "playwright test",
    "e2e:retry": "node scripts/e2e-retry.mjs",
    "e2e:local": "PW_USE_MANAGED_WEBSERVER=0 playwright test",
    "e2e:minimal": "playwright test --grep @minimal",
    "e2e:reconnect": "playwright test --grep @reconnect",
    "e2e:minimal:retry": "node scripts/e2e-minimal-retry.mjs",
    "e2e:minimal:local": "PW_USE_MANAGED_WEBSERVER=0 playwright test --grep @minimal",
    "e2e:headed": "playwright test --headed",
    "e2e:list": "playwright test --list",
    "release:readiness": "node scripts/release-readiness.mjs",
    "release:readiness:live": "P2P_RELEASE_CHECK_HEALTH=1 node scripts/release-readiness.mjs",
    "pre-release:full": "pnpm release:readiness && pnpm validate:full",
    "pre-release:live": "pnpm release:readiness:live && pnpm validate:full",
    "validate:security": "node scripts/validate-security.mjs",
    "validate:fast": "node scripts/validate-fast.mjs",
    "validate:full": "node scripts/validate-full.mjs",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "commitlint": "commitlint --edit",
    "validate:security:retry": "node scripts/validate-security-retry.mjs",
    "smoke:auth:retry": "node scripts/smoke-auth-retry.mjs"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/js": "^9.24.0",
    "@playwright/test": "^1.59.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-unicorn": "^58.0.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.1",
    "ws": "^8.20.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
